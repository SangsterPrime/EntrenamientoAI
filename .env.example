# Variables de entorno — NEXORA (Pipeline DataOps + IA + API)
# Copiar a .env y configurar según el entorno. NUNCA commitear el .env real.

# --- Entorno -----------------------------------------------------------------
# Identifica dónde corre el servicio: local | docker | render | production
ENVIRONMENT=local

# --- Base de datos (Neon / PostgreSQL) ---------------------------------------
# Cadena de conexión a PostgreSQL. Se admite cualquiera de estos nombres
# (prioridad: DATABASE_URL > DB_URL > NEON_DATABASE_URL).
# En Render: definir DATABASE_URL en el panel del Web Service.
# Formato: postgresql://usuario:contraseña@host.neon.tech/nombredb?sslmode=require
DATABASE_URL=postgresql://usuario:contraseña@ep-xxxxxx.us-east-2.aws.neon.tech/nexora?sslmode=require
# Alias soportados (opcionales, dejar vacíos si usas DATABASE_URL):
# DB_URL=
# NEON_DATABASE_URL=

# --- Seguridad de la API -----------------------------------------------------
# Si se define, los endpoints POST /train y POST /score exigen la cabecera
# 'X-API-Key' con este valor. Si se deja vacío, quedan abiertos (solo local).
ML_API_KEY=cambia-esta-clave-en-produccion

# --- Seudonimización (Ley 19.628 / Ley 21.719) -------------------------------
# Sal para el hash SHA-256 de identificadores. En producción usar un secreto.
NEXORA_SALT=nexora-demo-salt
