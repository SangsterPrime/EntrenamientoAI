# Variables de entorno — Pipeline Nexora (DataOps + IA)
# Copiar a .env y configurar según el entorno.

# Salt para seudonimización SHA-256 (Ley 19.628 / Ley 21.719)
NEXORA_SALT=nexora-demo-salt

# Conexión a Neon (PostgreSQL serverless)
# Obtén la URL desde tu panel de Neon: https://console.neon.tech
# Formato: postgresql://usuario:contraseña@ep-xxxxxx.us-east-2.aws.neon.tech/nombredb?sslmode=require
NEON_DATABASE_URL=postgresql://usuario:contraseña@ep-xxxxxx.us-east-2.aws.neon.tech/nexora?sslmode=require
